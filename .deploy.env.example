# Deployment configuration — copy this file to .deploy.env and fill in your values.
# .deploy.env is gitignored and never committed to the repository.

# Path to the SSH private key used to connect to the server.
SSH_KEY="$HOME/.ssh/id_rsa"

# SSH target: user@hostname or user@ip-address
SSH_HOST="user@your-server.example.com"

# Absolute path to the noctalum working directory on the remote host.
# The app binaries live in $REMOTE_WORK_DIR/app and data in $REMOTE_WORK_DIR/data.
REMOTE_WORK_DIR="/home/user/noctalum"
